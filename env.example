# Copy to ".env" in this directory (or set paths via --env-file).
# Keys are merged without overriding variables already set in your shell.

# --- Alpaca upstream (required when ALPACA_MOCK_ALPACA_DATE is set) ---
# ALPACA_UPSTREAM_API_KEY=
# ALPACA_UPSTREAM_SECRET_KEY=
# ALPACA_UPSTREAM_DATA_URL=https://data.alpaca.markets
# ALPACA_UPSTREAM_TRADING_URL=https://paper-api.alpaca.markets

# --- Historical replay day (US/Eastern); enables proxy to Alpaca Data API ---
# ALPACA_MOCK_ALPACA_DATE=2024-05-01
# ALPACA_MOCK_ALPACA_TIME=09:30
# ALPACA_MOCK_REPLAY_SPEED=3

# --- Server / local synthetic defaults (optional) ---
# ALPACA_MOCK_HOST=127.0.0.1
# ALPACA_MOCK_TRADING_PORT=19901
# ALPACA_MOCK_DATA_PORT=19902
# ALPACA_MOCK_CASH=25000   # local paper ledger only (GET /v2/account); not used to fake SIP replay
# ALPACA_MOCK_MARKET_CLOSED=true   # optional: force GET /v2/clock is_open=false
# ALPACA_MOCK_PRICE=AAPL=150,TSLA=200   # local synthetic mids, or replay fallback before upstream data seen
# ALPACA_MOCK_ACCESS_LOG=true
# ALPACA_MOCK_VERBOSE=false

# Alias for replay date:
# ALPACA_MOCK_DATE=2024-05-01
# ALPACA_MOCK_TIME=09:30
